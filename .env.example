DEPLOYMENT_MODE=selfhosted
PUBLIC_URL=http://localhost
OPENCIVIC_API_PORT=8100
OPENCIVIC_FRONTEND_PORT=3100
OPENCIVIC_GATEWAY_PORT=8088
# Gateway (nginx → APISIX). Use 8088 if 8080 is taken (common Docker conflict).
# OpenCivic port map: gateway 8088 · API 8100 · frontend 3100 · APISIX 9080 · Keycloak 8180
OPENCIVIC_APISIX_PORT=9080
OPENCIVIC_KEYCLOAK_PORT=8180
KEYCLOAK_ENABLED=false
KEYCLOAK_URL=http://127.0.0.1:8180
KEYCLOAK_REALM=dev
KEYCLOAK_CLIENT_ID=opencivic-portal
KEYCLOAK_CLIENT_SECRET=CHANGE_ME
EDGE_AUTH_ENABLED=true
GATEWAY_AUTH_SECRET=CHANGE_ME_GATEWAY_AUTH_SECRET
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_RO_PASSWORD=CHANGE_ME
KEYCLOAK_DB_PASSWORD=CHANGE_ME
VALKEY_PASSWORD=CHANGE_ME
QDRANT_API_KEY=CHANGE_ME
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_ADMIN_SECRET=CHANGE_ME
SECRET_KEY=CHANGE_ME_MINIMUM_32_CHARACTERS
GRAFANA_PASSWORD=CHANGE_ME
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME
LLM_PROVIDER=ollama
AI_MODE=disabled
LOG_LEVEL=INFO
DEV_AUTH_ENABLED=true
DEV_AUTH_TOKEN=dev-local-token-change-me
DEV_TENANT_ID=00000000-0000-0000-0000-000000000001
DEV_USER_ID=00000000-0000-0000-0000-000000000002
DEV_LICENCE_ID=00000000-0000-0000-0000-000000000003
