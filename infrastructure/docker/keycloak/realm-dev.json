{
  "realm": "dev",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "roles": {
    "realm": [
      { "name": "org_admin", "description": "Organisation administrator" },
      { "name": "data_publisher", "description": "Dataset publisher" },
      { "name": "data_steward", "description": "Data steward" },
      { "name": "developer", "description": "API developer" },
      { "name": "viewer", "description": "Authenticated viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "opencivic-portal",
      "name": "OpenCivic Portal",
      "enabled": true,
      "publicClient": false,
      "secret": "pilot-client-secret-change-me",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3100/*",
        "http://127.0.0.1:3100/*",
        "http://localhost:3100/login/callback",
        "http://127.0.0.1:3100/login/callback"
      ],
      "webOrigins": [
        "http://localhost:3100",
        "http://127.0.0.1:3100",
        "http://localhost:8080",
        "http://127.0.0.1:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_id",
            "claim.value": "00000000-0000-0000-0000-000000000001",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "publisher",
      "email": "publisher@opencivic.local",
      "firstName": "Dev",
      "lastName": "Publisher",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "publisher",
          "temporary": false
        }
      ],
      "realmRoles": ["data_publisher"],
      "attributes": {
        "tenant_id": ["00000000-0000-0000-0000-000000000001"]
      }
    }
  ]
}
