{
  "realm": "opencivic-template",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "roles": {
    "realm": [
      {"name": "org_admin", "description": "Organisation administrator"},
      {"name": "data_steward", "description": "Data governance gatekeeper"},
      {"name": "data_publisher", "description": "Data publisher"},
      {"name": "developer", "description": "API developer"},
      {"name": "viewer", "description": "Read-only access to restricted datasets"}
    ]
  },
  "clients": [
    {
      "clientId": "opencivic-portal",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    },
    {
      "clientId": "opencivic-api",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true
    }
  ]
}
